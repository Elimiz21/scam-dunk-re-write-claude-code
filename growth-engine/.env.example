# Database (same Supabase instance as main app)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Discovery APIs
SERPER_API_KEY=your_serper_key
PERPLEXITY_API_KEY=your_perplexity_key

# Drafting
OPENAI_API_KEY=your_openai_key

# X (Twitter) API v2 - for auto-posting
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# Growth engine API key (for admin dashboard communication)
GROWTH_ENGINE_API_KEY=your_shared_secret

# Optional: override schedule
DISCOVERY_INTERVAL_HOURS=4
MONITORING_INTERVAL_HOURS=12
