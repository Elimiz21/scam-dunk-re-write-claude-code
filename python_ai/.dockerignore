# Keep the image small and avoid shipping secrets / dev artifacts (PY-M12).

# Secrets and local env
.env
.env.*
!.env.example

# Tests
tests/
conftest.py
pytest.ini
test_*.py
*_test.py

# Training data (can be large; not needed at serve time)
training_data/

# Docs and notes
*.md

# Python caches / build junk
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
*.egg-info/
.venv/
venv/

# VCS
.git/
.gitignore

# NOTE: models/ is intentionally NOT ignored — the pre-trained RF/LSTM
# artifacts must ship in the image so the service does not train at startup.
